# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# sqlite (yerel)
prisma/*.db
prisma/*.db-journal

# Yerel görsel URL listesi (isteğe bağlı)
scripts/image-urls.json

# Admin’den yüklenen medya — repoda tutulur (Vercel’de de görünsün). Çok büyük dosyalar için Git LFS düşünün.
public/uploads/.DS_Store

# HTTrack yerel ayna (büyük; gerekirse kaldırıp repoya ekleyin)
public/webpace-mirror/

.vercel
.env*.local
