generator client {
  provider      = "prisma-client-js"
  /// Windows’ta geliştirme (`native`) + Vercel Linux üretim — aksi halde sunucuda Prisma motoru yüklenmeyebilir (500).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Çok kiracılı (SaaS) çekirdek — slug ile subdomain eşlemesi (ileride middleware).
model Tenant {
  id                     String              @id @default(cuid())
  slug                   String              @unique
  name                   String
  status                 String              @default("active")
  /// Modül bayrakları: randevu varsayılan açık; ticaret yalnızca { "commerce": true } ile açık seçilir.
  featuresJson           Json?
  /// Randevu/ticaret modülünü açma anahtarlarının bcrypt hash’leri — düz metin saklanmaz.
  moduleUnlockHashes     Json?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  domains                TenantDomain[]
  siteSettings           SiteSettings[]
  pages                  Page[]
  leads                  Lead[]
  crmContacts            CrmContact[]
  appointments           Appointment[]
  appointmentEvents      AppointmentEvent[]
  navItems               NavItem[]
  staffRoles             StaffRole[]
  staffUsers             StaffUser[]
  siteInstagramPosts     SiteInstagramPost[]
  siteYoutubeVideos      SiteYoutubeVideo[]
  siteTiktokVideos       SiteTiktokVideo[]
  cookieConsentLogs      CookieConsentLog[]
  commerceServicePrices          CommerceServicePrice[]
  commerceCustomerPriceOverrides CommerceCustomerPriceOverride[]
  commerceLedgerEntries            CommerceLedgerEntry[]
  commerceProducts                 CommerceProduct[]
  commerceStockMovements           CommerceStockMovement[]
  commerceCommissionRules          CommerceCommissionRule[]
  commerceCommissionAccruals       CommerceCommissionAccrual[]
  commercePackageTemplates         CommercePackageTemplate[]
  commercePackagePurchases         CommercePackagePurchase[]
  commercePackagePayments          CommercePackagePayment[]
  commerceCashReceipts             CommerceCashReceipt[]
  commerceCashDayCloses            CommerceCashDayClose[]
  demoPanelAudits                  DemoPanelAudit[]
}

/// Demo panel kullanıcısının yaptığı değişiklikler — admin tek seferde geri alabilir.
model DemoPanelAudit {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUsername String
  entityType    String
  entityId      String
  action        String
  label         String?
  beforeJson    String?
  afterJson     String?
  createdAt     DateTime  @default(now())
  revertedAt    DateTime?
  revertedBy    String?

  @@index([tenantId, revertedAt, createdAt])
  @@index([tenantId, entityType, entityId])
}

model TenantDomain {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  host      String   @unique
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Page {
  id                     String   @id @default(cuid())
  tenantId               String
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  slug                   String
  title                  String
  metaTitle              String?
  metaDescription        String?
  ogImage                String?
  canonicalPath          String?
  blocks                 String   @default("[]")
  blocksMobile           String?
  published              Boolean  @default(false)
  noIndex                Boolean  @default(false)
  /// Yayında ve endeks açıkken sitemap’e dahil (noIndex ile birlikte kullanılmaz)
  includeInSitemap       Boolean  @default(true)
  /// 0–1; boşsa site varsayılanı (iç sayfa 0.7)
  sitemapPriority        Float?
  /// always | hourly | daily | weekly | monthly | yearly | never; boşsa site varsayılanı
  sitemapChangeFrequency String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model SiteSettings {
  id                     Int      @id @default(1)
  siteName               String   @default("Güzellik Merkezi")
  /// Paketlenmiş tema kimliği: "default" | "cherry" | ileride src/themes altına ekledikleriniz
  activeThemeId          String   @default("default")
  /// public/uploads/{mediaUploadSlug}/ — panelden görsel indirme için klasör adı (isteğe bağlı)
  mediaUploadSlug        String?
  /// Üst şeritte kampanya / fiyat metni (Cherry temasında)
  headerPromoLine        String?
  /// Cherry üst pembe şerit (adres, kampanya, sosyal) — kapatılırsa yalnız ana menü kalır
  showHeaderTopBar       Boolean  @default(true)
  socialInstagramUrl     String?
  socialFacebookUrl      String?
  defaultMetaTitle       String?
  defaultMetaDescription String?
  businessJson           String?
  googleAnalyticsId      String?
  googleTagManagerId     String?
  facebookPixelId        String?
  customHeadHtml         String?
  whatsappNumber         String?
  seoKeywords            String?
  /// Instagram Graph API: İşletme IG kullanıcı id (içe aktarma için)
  instagramGraphUserId   String?
  /// Uzun ömürlü erişim jetonu — üretimde güvenli saklayın
  instagramAccessToken     String?
  /// Tema özelleştirici (renk, tipografi, genişlik) — JSON, src/lib/theme-tokens.ts
  themeTokensJson        String?
  /// Sabit üst içerik (menü altı, tüm sayfalar) — blok JSON dizisi, Admin → Site düzeni
  headerBlocks           String   @default("[]")
  /// Sabit alt bilgi (tüm sayfalar) — blok JSON dizisi; telif satırının üstünde
  footerBlocks           String   @default("[]")
  /// Sitemap’e eklenecek ek yollar — JSON dizi: [{ "path": "/x", "priority": 0.5, "changeFrequency": "weekly" }]
  sitemapExtrasJson      String   @default("[]")
  /// Ana sayfa sitemap önceliği (0–1)
  sitemapHomePriority    Float    @default(1)
  /// Diğer sayfalar için öntanımlı öncelik (0–1)
  sitemapPagePriority    Float    @default(0.7)
  /// Giden posta (SMTP) — randevu onay/red vb.; şifre panelde saklanır (üretimde güvenli ortam önerilir)
  smtpHost                 String?
  smtpPort                 Int?
  smtpUser                 String?
  smtpPass                 String?
  smtpSecure               Boolean  @default(false)
  /// Gönderen (örn. "Salon <randevu@alanadiniz.com>"); SPF/DKIM alan adınızda ayarlanmalı
  transactionalMailFrom  String?
  /// Çerez banner metni/aksiyon ayarı (JSON)
  cookieConsentJson      String?
  /// Yeni randevu talebi: admin bilgilendirme e-postaları (virgül veya alt satır ile çoklu; ENV ile birleştirilir)
  appointmentNotifyAdminEmails    String?
  /// Yeni randevu talebi: operatör bilgilendirme e-postaları (virgül veya alt satır ile çoklu; ENV ile birleştirilir)
  appointmentNotifyOperatorEmails String?
  /// Admin randevu panelinde «Liste fiyatları» varsa hizmet seçiminde TL göster (site ayarından aç/kapa)
  appointmentPanelShowListPrices Boolean @default(false)
  updatedAt              DateTime @updatedAt
  /// Kiracı bağlantısı — faz 1 opsiyonel; mevcut satır migrate ile dolar. Uygulama sorgusu değişmeden kalır.
  tenantId               String?  @unique
  tenant                 Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
}

/// Sitede gösterilecek Instagram gönderileri — yayın kutusu admin’den
model SiteInstagramPost {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  instagramId   String?
  permalink     String
  caption       String?
  mediaUrl      String?
  thumbnailUrl  String?
  mediaType     String?
  published     Boolean  @default(false)
  sortOrder     Int      @default(0)
  source        String   @default("manual")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, instagramId])
  @@unique([tenantId, permalink])
  @@index([tenantId])
}

/// YouTube vitrinı — video kimliği (11 karakter) + isteğe bağlı başlık
model SiteYoutubeVideo {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  videoId    String
  title      String?
  watchUrl   String?
  published  Boolean  @default(false)
  sortOrder  Int      @default(0)
  source     String   @default("manual")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, videoId])
  @@index([tenantId])
}

/// TikTok vitrinı — paylaşım bağlantısı; küçük resim oEmbed ile dolar
model SiteTiktokVideo {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  permalink     String
  videoId       String?
  thumbnailUrl  String?
  title         String?
  published     Boolean  @default(false)
  sortOrder     Int      @default(0)
  source        String   @default("manual")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, permalink])
  @@index([tenantId])
}

model Lead {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name      String
  email     String?
  phone     String?
  message   String?
  source    String?
  status    String   @default("new")
  notes     String?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

/// Telefonla eşleşen müşteri kartı (randevu taleplerinden otomatik dolar)
model CrmContact {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  phoneKey     String
  name         String
  email        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  commercePriceOverrides   CommerceCustomerPriceOverride[]
  commerceLedgerEntries    CommerceLedgerEntry[]
  commercePackagePurchases CommercePackagePurchase[]
  commerceCashReceipts     CommerceCashReceipt[]

  @@unique([tenantId, phoneKey])
  @@index([tenantId])
}

model Appointment {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  startAt        DateTime
  endAt          DateTime?
  serviceName    String?
  /// Formda gösterilen / müşterinin gördüğü fiyat (kuruş, TRY)
  quotedPriceMinor Int?
  /// catalog | override | none
  priceSource    String?
  clientName     String
  clientEmail    String?
  clientPhone    String?
  /// normalizePhoneKey(clientPhone) — çift kayıt ve CRM eşlemesi
  clientPhoneKey String?
  /// normalizeClientNameKey(clientName)
  clientNameKey  String?
  notes          String?
  status         String      @default("pending")
  /// Müşteri iptal kodu (hash) — düz kod saklanmaz
  cancelCodeHash String?
  /// Destek amaçlı yalnız son 4 hane
  cancelCodeLast4 String?
  /// Müşteri iptal bağlantı token hash
  cancelTokenHash String?
  /// Token son geçerlilik zamanı
  cancelTokenExpiresAt DateTime?
  createdAt      DateTime    @default(now())
  crmContactId   String?
  crmContact     CrmContact? @relation(fields: [crmContactId], references: [id], onDelete: SetNull)
  events         AppointmentEvent[]
  commissionAccruals CommerceCommissionAccrual[]
  commerceCashReceipts CommerceCashReceipt[]

  @@index([tenantId, startAt, serviceName, status])
  @@index([cancelTokenHash])
}

model AppointmentEvent {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  eventType     String
  channel       String?
  outcome       String
  actor         String?
  detailsJson   String?
  createdAt     DateTime    @default(now())

  @@index([tenantId, appointmentId, createdAt])
  @@index([tenantId, eventType, createdAt])
}

/// Üst menü / alt menü — parentId null ise kök öğe
/// menuSlug: "header" = sabit üst şerit menüsü; "footer" = alt bilgi / widget için ayrı liste
model NavItem {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  menuSlug     String    @default("header")
  parentId     String?
  parent       NavItem?  @relation("NavTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     NavItem[] @relation("NavTree")
  label        String
  href         String
  sortOrder    Int       @default(0)
  published    Boolean   @default(true)
  openInNewTab Boolean   @default(false)

  @@index([tenantId, menuSlug, parentId, sortOrder])
}

/// Panel rolleri — permissionsJson: ["content.pages", "site.settings", ...]
model StaffRole {
  id               String          @id @default(cuid())
  tenantId         String
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  slug             String
  label            String
  permissionsJson  String
  userAssignments  StaffUserRole[]
  createdAt        DateTime        @default(now())

  @@unique([tenantId, slug])
  @@index([tenantId])
}

/// Personel kullanıcı ↔ rol (bir kullanıcıya birden fazla rol).
model StaffUserRole {
  staffUserId String
  roleId      String
  staffUser   StaffUser @relation(fields: [staffUserId], references: [id], onDelete: Cascade)
  role        StaffRole @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([staffUserId, roleId])
  @@index([staffUserId])
  @@index([roleId])
}

model StaffUser {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  username     String
  passwordHash String
  displayName  String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  roleAssignments StaffUserRole[]

  pushSubscriptions StaffPushSubscription[]
  commerceCommissionAccruals CommerceCommissionAccrual[]
  cashReceiptsRecorded       CommerceCashReceipt[] @relation("CashReceiptRecordedBy")
  cashDayClosesStaff         CommerceCashDayClose[] @relation("CashDayCloseByStaff")

  @@unique([tenantId, username])
  @@index([tenantId])
}

// --- Ticaret (fiyat, paket, cari, stok, prim) — tenant kapsamlı ---

/// Menü etiketi ile eşleşen genel liste fiyatı (kuruş, TRY)
model CommerceServicePrice {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  serviceKey  String
  label       String
  priceMinor  Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, serviceKey])
  @@index([tenantId])
}

/// CRM müşterisine özel hizmet fiyatı (serviceKey ile katalogu override eder)
model CommerceCustomerPriceOverride {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  crmContactId String
  crmContact   CrmContact @relation(fields: [crmContactId], references: [id], onDelete: Cascade)
  serviceKey   String
  priceMinor   Int
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([tenantId, crmContactId, serviceKey])
  @@index([tenantId])
  @@index([crmContactId])
}

/// Cari: charge pozitif (alacak artar), payment negatif (tahsilat)
model CommerceLedgerEntry {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  crmContactId String
  crmContact   CrmContact @relation(fields: [crmContactId], references: [id], onDelete: Cascade)
  occurredAt   DateTime   @default(now())
  kind         String
  amountMinor  Int
  currency     String     @default("TRY")
  memo         String?
  refType      String?
  refId        String?
  createdAt    DateTime   @default(now())

  cashReceipt CommerceCashReceipt?

  @@index([tenantId, crmContactId, occurredAt])
}

/// Kasa tahsilatı: tutar kasaya giren pozitif kuruş; isteğe bağlı cari `payment` satırı ile eşlenir.
model CommerceCashReceipt {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  occurredAt    DateTime @default(now())
  amountMinor   Int
  method        String
  memo          String?

  /// appointment | walk_in | manual
  sourceKind    String   @default("manual")
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  crmContactId  String?
  crmContact    CrmContact? @relation(fields: [crmContactId], references: [id], onDelete: SetNull)

  staffUserId String?
  staffUser   StaffUser? @relation("CashReceiptRecordedBy", fields: [staffUserId], references: [id], onDelete: SetNull)

  ledgerEntryId String? @unique
  ledgerEntry   CommerceLedgerEntry? @relation(fields: [ledgerEntryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([tenantId, occurredAt])
  @@index([tenantId, appointmentId])
}

/// Gün sonu kasa özeti (iş günü başına bir kayıt).
model CommerceCashDayClose {
  id                 String   @id @default(cuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  businessDate       DateTime @db.Date
  closedAt           DateTime @default(now())
  staffUserId        String?
  staffUser          StaffUser? @relation("CashDayCloseByStaff", fields: [staffUserId], references: [id], onDelete: SetNull)
  expectedTotalMinor Int?
  countedTotalMinor    Int?
  notes                String?

  @@unique([tenantId, businessDate])
  @@index([tenantId, businessDate])
}

model CommerceProduct {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  sku            String
  name           String
  salePriceMinor Int      @default(0)
  costMinor      Int?
  trackStock     Boolean  @default(true)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stockMovements CommerceStockMovement[]

  @@unique([tenantId, sku])
  @@index([tenantId])
}

model CommerceStockMovement {
  id         String          @id @default(cuid())
  tenantId   String
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  productId  String
  product    CommerceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  occurredAt DateTime        @default(now())
  qty        Int
  reason     String
  memo       String?
  refType    String?
  refId      String?

  @@index([tenantId, productId, occurredAt])
}

model CommerceCommissionRule {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name       String
  serviceKey String?
  percentBps Int?
  fixedMinor Int?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  accruals CommerceCommissionAccrual[]

  @@index([tenantId])
}

model CommerceCommissionAccrual {
  id                String                  @id @default(cuid())
  tenantId          String
  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  appointmentId     String?
  appointment       Appointment?            @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  staffUserId       String?
  staffUser         StaffUser?              @relation(fields: [staffUserId], references: [id], onDelete: SetNull)
  staffNameSnapshot String?
  ruleId            String?
  rule              CommerceCommissionRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  amountMinor       Int
  status            String                  @default("pending")
  memo              String?
  createdAt         DateTime                @default(now())

  @@index([tenantId, appointmentId])
  @@index([tenantId, status])
}

model CommercePackageTemplate {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name           String
  listPriceMinor Int      @default(0)
  validityDays   Int?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lines     CommercePackageTemplateLine[]
  purchases CommercePackagePurchase[]

  @@index([tenantId])
}

model CommercePackageTemplateLine {
  id         String                  @id @default(cuid())
  templateId String
  template   CommercePackageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  serviceKey String
  sessions   Int                     @default(1)

  @@index([templateId])
}

model CommercePackagePurchase {
  id              String                  @id @default(cuid())
  tenantId        String
  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  crmContactId    String
  crmContact      CrmContact              @relation(fields: [crmContactId], references: [id], onDelete: Cascade)
  templateId      String
  template        CommercePackageTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  purchasedAt     DateTime                @default(now())
  expiresAt       DateTime?
  /// Anlaşılan paket bedeli (kuruş). Tahsilat toplamı buna göre kalan borcu verir.
  salePriceMinor  Int?
  /// Geriye uyumluluk: eski kayıtlarda yalnızca bu alan dolu olabilir.
  paidAmountMinor Int?
  status          String                  @default("active")

  credits  CommercePackageCredit[]
  payments CommercePackagePayment[]

  @@index([tenantId, crmContactId])
}

/// Paket satışına yapılan tahsilat (nakit, kart, havale…); cariye payment satırı eşlenir.
model CommercePackagePayment {
  id          String                  @id @default(cuid())
  tenantId    String
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  purchaseId  String
  purchase    CommercePackagePurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  amountMinor Int
  method      String
  memo        String?
  paidAt      DateTime                @default(now())
  createdAt   DateTime                @default(now())

  @@index([tenantId, purchaseId])
}

model CommercePackageCredit {
  id         String                  @id @default(cuid())
  purchaseId String
  purchase   CommercePackagePurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  serviceKey String
  remaining  Int

  @@unique([purchaseId, serviceKey])
}

/// Web Push (VAPID): yeni randevu gibi olaylarda tarayıcı bildirimi
model StaffPushSubscription {
  id               String    @id @default(cuid())
  staffId          String
  staff            StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)
  endpoint         String    @unique
  /// PushSubscription.toJSON() tam metni (endpoint + keys)
  subscriptionJson String    @db.Text
  userAgent        String?
  createdAt        DateTime  @default(now())

  @@index([staffId])
}

model CookieConsentLog {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  consentKey    String
  decision      String
  preferencesJson String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([tenantId, consentKey, createdAt])
}
